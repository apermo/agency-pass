{
    "name": "apermo/agency-pass",
    "description": "A WordPress agency-pass plugin.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Christoph Daum",
            "email": "me@christoph-daum.de"
        }
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://wpackagist.org"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "apermo/apermo-coding-standards": "^2.0",
        "apermo/phpstan-wordpress-rules": "^0.2",
        "brain/monkey": "^2.6",
        "composer/installers": "^2.0",
        "phpstan/extension-installer": "^1.4",
        "phpunit/phpunit": "^11.0",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "wpackagist-plugin/wp-security-audit-log": "*",
        "yoast/phpunit-polyfills": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Agency_Pass\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Agency_Pass\\Tests\\": "tests/"
        }
    },
    "extra": {
        "installer-paths": {
            ".ddev/wordpress/wp-content/plugins/{$name}/": [
                "type:wordpress-plugin"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration",
        "analyse": "phpstan analyse --memory-limit=512M",
        "cs": "phpcs",
        "cs:fix": "phpcbf"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    }
}
